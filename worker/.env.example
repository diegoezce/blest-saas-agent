# ── Blest Worker — config for Windows mini PC ──────────────────────────────
# Copy this file to worker/.env and fill in the values.
# This file is .gitignored — NEVER commit the real .env.

# Required
DATABASE_URL=postgresql+psycopg2://user:pass@host.railway.app:PORT/railway
ANTHROPIC_API_KEY=sk-ant-...

# Zoho Mail OAuth (self-client)
# After creating the self-client app at api-console.zoho.com, run:
#   python run.py --zoho-auth <grant_token>
# That stores tokens in .zoho_tokens.json (project root). No need to set these here
# UNLESS you want to override the token file (e.g. production env vars on Railway).
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Email verification (same keys as Railway)
EMAIL_VERIFIER_PROVIDER=millionverifier   # or: neverbounce
EMAIL_VERIFIER_API_KEY=    # MillionVerifier (used when provider=millionverifier)
NEVERBOUNCE_API_KEY=       # NeverBounce (used when provider=neverbounce; 1,000 free/month)
HUNTER_API_KEY=            # Hunter.io (25 free/month)

# Optional tuning
FAST_MODEL=claude-haiku-4-5-20251001
WORKER_ENRICH_BATCH=15     # contacts to enrich per run
WORKER_PUSH_BATCH=15       # drafts to push per run
WORKER_ENRICH_DELAY=3      # seconds between enrichment calls (rate limiting)
WORKER_PUSH_DELAY=1        # seconds between Zoho API calls
WORKER_RETRY_FAILED=true   # also retry previously-failed named contacts (no email yet)
WORKER_MAX_ATTEMPTS=3      # max enrichment passes per contact (incl. first)
WORKER_CHECK_BOUNCES=true  # phase 3: scan Zoho inbox + mark bounced contacts (needs read scope)
WORKER_FOLLOWUP=true       # phase 4: detect replies + push follow-up drafts (needs read scope)
WORKER_FOLLOWUP_BATCH=15   # follow-up drafts to push per run
WORKER_FOLLOWUP_DELAY=1    # seconds between Zoho API calls
