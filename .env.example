# === AI MODELS ===
ANTHROPIC_API_KEY=your-anthropic-api-key
FAST_MODEL=claude-haiku-4-5-20251001
REASONING_MODEL=claude-sonnet-4-6

# === SEARCH ===
TAVILY_API_KEY=your-tavily-api-key
TAVILY_MAX_RESULTS=10
TAVILY_SEARCH_DEPTH=basic

# === DATABASE ===
DATABASE_URL=postgresql+psycopg2://blest:blest@localhost:5432/blest_saas_leads

# === WEB UI ===
WEB_PASSWORD=blest2024
TRIGGER_PASSWORD=blest2024

# === SCHEDULER ===
SCHEDULE_TIME=08:00
SCHEDULE_DAYS=mon-thu
SCHEDULER_TIMEZONE=America/Argentina/Buenos_Aires

# === WORKFLOW TUNING ===
DISCOVERY_QUERIES_PER_RUN=8
MAX_COMPANIES_TO_SCORE=30
MAX_COMPANIES_FOR_CONTACTS=20
MAX_COMPANIES_FOR_INSIGHTS=10
MAX_COMPANIES_FOR_OUTREACH=5

# === BUSINESS TARGETING ===
TARGET_CITIES=Buenos Aires,Córdoba,Rosario,Mendoza,Neuquén
TARGET_INDUSTRIES=technology,consulting,fintech,legaltech,accounting,professional_services,oil_gas,energy
MIN_EMPLOYEES=20
MAX_EMPLOYEES=500

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# === REPORTS ===
REPORT_OUTPUT_DIR=./reports

# === ZOHO MAIL INTEGRATION ===
# 1. Register a Self-Client app at https://api-console.zoho.com
# 2. Run locally: python run.py --zoho-auth <grant_token>
# 3. Copy values from .zoho_tokens.json into Railway env vars:
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNT_ID=
ZOHO_FROM_ADDRESS=

# === CONTACT ENRICHMENT ===
# Layer 2 verification provider: "millionverifier" (default) or "neverbounce"
EMAIL_VERIFIER_PROVIDER=millionverifier
# MillionVerifier — used when EMAIL_VERIFIER_PROVIDER=millionverifier
# https://www.millionverifier.com — pay-per-verification, ~$0.003/check
EMAIL_VERIFIER_API_KEY=
# NeverBounce — used when EMAIL_VERIFIER_PROVIDER=neverbounce
# https://neverbounce.com — 1,000 free/month, pay-as-you-go after
NEVERBOUNCE_API_KEY=

# Hunter.io — email finder fallback (Layer 3)
# https://hunter.io — 25 free searches/month; paid plans from $49/mo
HUNTER_API_KEY=
